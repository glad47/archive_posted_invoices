<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Form View: Add Archive / Unarchive button on invoice form     -->
    <!-- ============================================================ -->
    <record id="view_move_form_archive_button" model="ir.ui.view">
        <field name="name">account.move.form.archive.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_archive"
                        string="Archive"
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': [('active', '=', False)]}"
                        confirm="Are you sure you want to archive this invoice? This will create a reversal entry to clean all journal movements."
                        groups="account.group_account_invoice"/>
                <button name="action_unarchive"
                        string="Unarchive"
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': [('active', '=', True)]}"
                        groups="account.group_account_invoice"/>
            </xpath>
            <!-- Show warning banner and reversal link when archived -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning text-center mb-0"
                     role="alert"
                     attrs="{'invisible': [('active', '=', True)]}">
                    <strong>This invoice has been archived and its journal entries have been reversed.</strong>
                    <field name="reversal_move_id" invisible="1"/>
                    <br/>
                    <button name="action_unarchive"
                            string="Click here to unarchive and restore journal entries"
                            type="object"
                            class="btn-link p-0 ms-1"
                            groups="account.group_account_invoice"/>
                </div>
            </xpath>
            <!-- Add reversal move link in the 'Other Info' tab -->
            <xpath expr="//page[@id='other_tab_entry']//group[last()]" position="inside">
                <field name="reversal_move_id"
                       attrs="{'invisible': [('reversal_move_id', '=', False)]}"
                       readonly="1"/>
                <field name="archived_by_module" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search View: Add 'Archived' filter                           -->
    <!-- ============================================================ -->
    <record id="view_account_move_search_archive" model="ir.ui.view">
        <field name="name">account.move.search.archive</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/filter[last()]" position="after">
                <separator/>
                <filter string="Archived"
                        name="archived"
                        domain="[('active', '=', False)]"/>
                <filter string="All (Including Archived)"
                        name="all_including_archived"
                        domain="['|', ('active', '=', True), ('active', '=', False)]"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Server Action: Bulk Archive from list view                   -->
    <!-- ============================================================ -->
    <record id="action_archive_invoices" model="ir.actions.server">
        <field name="name">Archive Invoices (with reversal)</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_archive_invoices()
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Server Action: Bulk Unarchive from list view                 -->
    <!-- ============================================================ -->
    <record id="action_unarchive_invoices" model="ir.actions.server">
        <field name="name">Unarchive Invoices (restore entries)</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_unarchive_invoices()
        </field>
    </record>

</odoo>
