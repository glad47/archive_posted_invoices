<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View: Archive / Unarchive buttons (both use wizards) -->
    <record id="view_move_form_archive_button" model="ir.ui.view">
        <field name="name">account.move.form.archive.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="is_archived" invisible="1"/>
                <field name="archive_reversal_id" invisible="1"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_open_archive_wizard"
                        string="Archive"
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': [('is_archived', '=', True)]}"
                        groups="account.group_account_invoice"/>
                <button name="action_open_unarchive_wizard"
                        string="Unarchive"
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': [('is_archived', '=', False)]}"
                        groups="account.group_account_invoice"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="alert alert-warning text-center"
                     role="alert"
                     attrs="{'invisible': [('is_archived', '=', False)]}">
                    <strong>This invoice is archived. Its journal entries have been reversed.</strong>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Tree View: Show archived indicator -->
    <record id="view_move_tree_archive" model="ir.ui.view">
        <field name="name">account.move.tree.archive</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="is_archived" string="Archived" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Search View: Archived filters -->
    <record id="view_account_move_search_archive" model="ir.ui.view">
        <field name="name">account.move.search.archive</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/filter[last()]" position="after">
                <separator/>
                <filter string="Archived"
                        name="filter_archived"
                        domain="[('is_archived', '=', True)]"/>
                <filter string="Not Archived"
                        name="filter_not_archived"
                        domain="[('is_archived', '=', False)]"/>
            </xpath>
        </field>
    </record>

    <!-- Server Action: Bulk Archive -->
    <record id="action_bulk_archive_invoices" model="ir.actions.server">
        <field name="name">Archive (with reversal)</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_open_archive_wizard()
        </field>
    </record>

    <!-- Server Action: Bulk Unarchive -->
    <record id="action_bulk_unarchive_invoices" model="ir.actions.server">
        <field name="name">Unarchive (restore entries)</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_open_unarchive_wizard()
        </field>
    </record>

</odoo>
